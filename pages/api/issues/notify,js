// pages/api/issues/notify.js
// Called when "Assign & notify" is triggered.
// Sends an AI-summarized email (SendGrid) + SMS (Twilio) to all assigned folks.

export default async function handler(req, res) {
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' })

  const {
    issueTitle,
    issueDescription,
    realIssue,
    locationName,
    urgency,
    assignedBy,
    recipients, // [{ name, email, phone }]
  } = req.body

  if (!recipients || recipients.length === 0) {
    return res.status(400).json({ error: 'No recipients provided' })
  }

  const sgKey = process.env.SENDGRID_API_KEY
  const fromEmail = process.env.NOTIFY_FROM_EMAIL
  const twilioSid = process.env.TWILIO_ACCOUNT_SID
  const twilioToken = process.env.TWILIO_AUTH_TOKEN
  const twilioFrom = process.env.TWILIO_FROM_NUMBER

  if (!sgKey || !fromEmail) {
    return res.status(500).json({ error: 'Email not configured' })
  }

  // ── 1. AI summary via Claude ────────────────────────────────────────────
  let aiSummary = issueDescription || ''
  try {
    const prompt = [
      issueTitle && `Issue: ${issueTitle}`,
      issueDescription && `Description: ${issueDescription}`,
      realIssue && `Root cause identified: ${realIssue}`,
    ].filter(Boolean).join('\n')

    const claudeRes = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-version': '2023-06-01',
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 200,
        system: 'You summarize gym facility issues in 2 plain sentences for staff who need to act on them. Be direct and practical. No bullet points. No preamble.',
        messages: [{ role: 'user', content: `Summarize this issue for the assigned staff member:\n\n${prompt}` }],
      }),
    })
    const claudeData = await claudeRes.json()
    const text = claudeData?.content?.find(b => b.type === 'text')?.text
    if (text) aiSummary = text.trim()
  } catch (e) {
    console.error('Claude summary failed, falling back to description:', e)
  }

  // ── 2. Parse location display ───────────────────────────────────────────
  const locationParts = (locationName || '').split(' — ')
  const gymLocation = locationParts[0] || ''
  const area = locationParts[1] || ''
  const locationDisplay = [gymLocation, area].filter(Boolean).join(' — ')
  const urgencyLabel = { high: 'High 🔴', medium: 'Medium 🟡', low: 'Low 🟢' }[urgency] || urgency

  const emailSubject = `[${gymLocation || 'Issues Tracker'}] You've been assigned: ${issueTitle}`

  const recipientNames = recipients.map(r => r.name).filter(Boolean).join(', ')

  const emailHtml = `
    <div style="font-family: sans-serif; max-width: 560px; margin: 0 auto; color: #222;">
      <div style="background: #E85D26; padding: 16px 24px; border-radius: 8px 8px 0 0;">
        <span style="color: white; font-weight: 700; font-size: 16px;">BL Issues Tracker</span>
      </div>
      <div style="border: 1px solid #e0e0e0; border-top: none; padding: 24px; border-radius: 0 0 8px 8px;">
        <p style="margin: 0 0 8px; font-size: 13px; color: #888;">Assigned by ${assignedBy}</p>
        <h2 style="margin: 0 0 12px; font-size: 20px;">${issueTitle}</h2>
        <p style="margin: 0 0 20px; color: #444; font-size: 14px; line-height: 1.6;">${aiSummary}</p>
        <table style="width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 20px;">
          ${locationDisplay ? `<tr><td style="padding: 6px 0; color: #888; width: 120px;">Location</td><td style="font-weight: 500;">${locationDisplay}</td></tr>` : ''}
          <tr><td style="padding: 6px 0; color: #888;">Urgency</td><td style="font-weight: 500;">${urgencyLabel}</td></tr>
          <tr><td style="padding: 6px 0; color: #888;">Assigned to</td><td style="font-weight: 500;">${recipientNames}</td></tr>
        </table>
        <p style="margin: 0; font-size: 12px; color: #aaa;">Log in to the Issues Tracker to view full details and update progress.</p>
      </div>
    </div>
  `

  const errors = []

  // ── 3. Send email via SendGrid ──────────────────────────────────────────
  const emailRecipients = recipients.filter(r => r.email)
  if (emailRecipients.length > 0) {
    try {
      const sgRes = await fetch('https://api.sendgrid.com/v3/mail/send', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${sgKey}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          personalizations: [{ to: emailRecipients.map(r => ({ email: r.email, name: r.name })) }],
          from: { email: fromEmail, name: 'BL Issues Tracker' },
          subject: emailSubject,
          content: [{ type: 'text/html', value: emailHtml }],
        }),
      })
      if (!sgRes.ok) {
        const detail = await sgRes.text()
        console.error('SendGrid error:', detail)
        errors.push(`Email failed: ${detail}`)
      }
    } catch (e) {
      console.error('SendGrid exception:', e)
      errors.push(`Email exception: ${e.message}`)
    }
  }

  // ── 4. Send SMS via Twilio ──────────────────────────────────────────────
  const smsBody = `[BL Issues Tracker] You've been assigned an issue at ${gymLocation || 'the gym'}: ${aiSummary} — Assigned by ${assignedBy}`
  // Twilio has a 1600 char limit; truncate cleanly
  const smsBodyTrimmed = smsBody.length > 1550 ? smsBody.slice(0, 1547) + '...' : smsBody

  if (twilioSid && twilioToken && twilioFrom) {
    const smsRecipients = recipients.filter(r => r.phone)
    for (const recipient of smsRecipients) {
      try {
        const body = new URLSearchParams({
          From: twilioFrom,
          To: recipient.phone,
          Body: smsBodyTrimmed,
        })
        const twilioRes = await fetch(
          `https://api.twilio.com/2010-04-01/Accounts/${twilioSid}/Messages.json`,
          {
            method: 'POST',
            headers: {
              'Authorization': 'Basic ' + Buffer.from(`${twilioSid}:${twilioToken}`).toString('base64'),
              'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: body.toString(),
          }
        )
        if (!twilioRes.ok) {
          const detail = await twilioRes.text()
          console.error(`Twilio error for ${recipient.name}:`, detail)
          errors.push(`SMS failed for ${recipient.name}`)
        }
      } catch (e) {
        console.error(`Twilio exception for ${recipient.name}:`, e)
        errors.push(`SMS exception for ${recipient.name}: ${e.message}`)
      }
    }
  }

  return res.status(200).json({
    success: errors.length === 0,
    emailsSent: emailRecipients.length,
    smsSent: twilioSid ? recipients.filter(r => r.phone).length : 0,
    errors: errors.length > 0 ? errors : undefined,
  })
}